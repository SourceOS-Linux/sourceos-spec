{
  "id": "urn:srcos:skill:obfuscation-runner",
  "type": "SkillManifest",
  "specVersion": "2.0.0",
  "name": "obfuscation-runner",
  "version": "1.0.0",
  "entryDoc": "skills/obfuscation-runner/README.md",
  "description": "Runs the k-anonymisation obfuscation workload on a health dataset before export. Validates the active CapabilityToken, launches the obfuscator container, and records provenance.",
  "activationRules": {
    "commands": ["obfuscate", "run-obfuscator"],
    "filePatterns": ["**/obfuscation-config.yaml"],
    "intentTags": ["data-obfuscation", "privacy-export"]
  },
  "requires": {
    "binaries": ["docker"],
    "anyBins": [],
    "tools": ["bash"]
  },
  "executionSurfaceRef": null,
  "policyBindings": ["urn:srcos:policy:export_health_restricted"],
  "artifactOutputs": ["run-record", "provenance-record"],
  "reviewMode": false,
  "allowShellExecution": true,
  "protectedPaths": [".env", "*.key"]
}
