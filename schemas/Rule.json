{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/Rule.json",
  "title": "Rule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "effect",
    "operations"
  ],
  "properties": {
    "effect": {
      "enum": [
        "permit",
        "deny"
      ]
    },
    "operations": {
      "type": "array",
      "items": {
        "enum": [
          "read",
          "write",
          "export",
          "transform",
          "share"
        ]
      }
    },
    "condition": {
      "$ref": "PolicyCondition.json"
    }
  }
}