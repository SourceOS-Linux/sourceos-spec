{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/Trigger.json",
  "title": "Trigger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind"
  ],
  "properties": {
    "kind": {
      "enum": [
        "schedule",
        "event",
        "manual"
      ]
    },
    "schedule": {
      "type": [
        "string",
        "null"
      ]
    },
    "eventType": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}