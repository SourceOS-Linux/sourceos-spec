{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/WorkflowEdge.json",
  "title": "WorkflowEdge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "from",
    "to"
  ],
  "properties": {
    "from": {
      "type": "string",
      "description": "nodeId of the upstream (source) WorkflowNode."
    },
    "to": {
      "type": "string",
      "description": "nodeId of the downstream (sink) WorkflowNode."
    }
  },
  "description": "A directed dependency edge between two WorkflowNode identifiers within a WorkflowSpec DAG, establishing execution order and data-flow direction."
}