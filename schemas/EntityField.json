{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/EntityField.json",
  "title": "EntityField",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "dataType"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "dataType": {
      "type": "string"
    },
    "nullable": {
      "type": "boolean",
      "default": true
    },
    "validValues": {
      "$ref": "ValidValues.json"
    },
    "tags": {
      "type": "array",
      "items": {
        "$ref": "TagAssignment.json"
      }
    },
    "glossaryTerms": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^urn:srcos:glossary:"
      }
    }
  }
}