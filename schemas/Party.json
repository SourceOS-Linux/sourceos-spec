{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/Party.json",
  "title": "Party",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "partyId",
    "name",
    "kind"
  ],
  "properties": {
    "partyId": {
      "type": "string",
      "pattern": "^urn:srcos:party:"
    },
    "name": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "person",
        "org",
        "service"
      ]
    },
    "authorityLinks": {
      "type": "array",
      "items": {
        "$ref": "AuthorityLink.json"
      }
    }
  }
}