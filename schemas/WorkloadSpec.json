{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/WorkloadSpec.json",
  "title": "WorkloadSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workloadId",
    "kind",
    "image",
    "entrypoint"
  ],
  "properties": {
    "workloadId": {
      "type": "string",
      "pattern": "^urn:srcos:workload:"
    },
    "kind": {
      "enum": [
        "sparkJob",
        "container",
        "function",
        "streamProcessor"
      ]
    },
    "image": {
      "type": "string"
    },
    "entrypoint": {
      "type": "string"
    },
    "params": {
      "type": "object",
      "additionalProperties": true
    }
  }
}