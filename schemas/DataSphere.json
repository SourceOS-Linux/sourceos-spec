{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/DataSphere.json",
  "title": "DataSphere",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sphereId",
    "name",
    "boundary",
    "controls"
  ],
  "properties": {
    "sphereId": {
      "type": "string",
      "pattern": "^urn:srcos:sphere:",
      "description": "Stable URN identifying this DataSphere."
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of this DataSphere."
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "zone": {
          "type": "string"
        },
        "networkPolicy": {
          "type": [
            "string",
            "null"
          ]
        },
        "storagePolicy": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "description": "Zone, network-policy, and storage-policy constraints defining the perimeter."
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accessEnforcer": {
          "type": "string"
        },
        "provenance": {
          "enum": [
            "off",
            "hashes",
            "signed"
          ]
        },
        "containerAttestation": {
          "enum": [
            "none",
            "basic",
            "strict"
          ]
        }
      },
      "description": "Access enforcer, provenance mode, and container attestation settings."
    }
  },
  "description": "A logical isolation boundary within which workloads execute, defined by zone constraints, network policies, storage policies, and access-control settings."
}