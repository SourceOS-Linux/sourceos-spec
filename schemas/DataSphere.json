{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/DataSphere.json",
  "title": "DataSphere",
  "description": "A bounded, policy-controlled execution environment. Defines the zone, network policy, and integrity controls under which a workload runs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sphereId",
    "name",
    "boundary",
    "controls"
  ],
  "properties": {
    "sphereId": {
      "type": "string",
      "pattern": "^urn:srcos:sphere:",
      "description": "Stable URN identifier. Pattern: urn:srcos:sphere:<local-id>"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for this data sphere."
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "zone": {
          "type": "string"
        },
        "networkPolicy": {
          "type": [
            "string",
            "null"
          ]
        },
        "storagePolicy": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "description": "Zone and policy boundaries: the logical zone name, an optional network policy reference, and an optional storage policy reference."
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accessEnforcer": {
          "type": "string"
        },
        "provenance": {
          "enum": [
            "off",
            "hashes",
            "signed"
          ]
        },
        "containerAttestation": {
          "enum": [
            "none",
            "basic",
            "strict"
          ]
        }
      },
      "description": "Enforcement controls: the access enforcer identifier, provenance recording level, and container attestation level."
    }
  }
}
