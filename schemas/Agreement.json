{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/Agreement.json",
  "title": "Agreement",
  "description": "A data-sharing agreement between one or more parties. Captures the license, restrictions, retention period, jurisdiction, and effective date range.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "specVersion",
    "title",
    "parties",
    "terms",
    "effective"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:srcos:agreement:",
      "description": "Stable URN identifier. Pattern: urn:srcos:agreement:<local-id>"
    },
    "type": {
      "const": "Agreement",
      "description": "Discriminator constant \u2014 always \"Agreement\"."
    },
    "specVersion": {
      "type": "string",
      "description": "Spec version of this document, e.g. \"2.0.0\"."
    },
    "title": {
      "type": "string",
      "description": "Human-readable name of the agreement."
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional longer description of the agreement's purpose or context."
    },
    "parties": {
      "type": "array",
      "items": {
        "$ref": "Party.json"
      },
      "minItems": 1,
      "description": "The signatories to this agreement. At least one party is required."
    },
    "terms": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "license",
        "restrictions"
      ],
      "properties": {
        "license": {
          "type": "string"
        },
        "restrictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attributionRequired": {
          "type": "boolean",
          "default": false
        },
        "dataRetentionDays": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "jurisdiction": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "description": "The legal and operational terms: license identifier, restrictions list, attribution requirement, retention period, and jurisdiction."
    },
    "effective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start"
      ],
      "properties": {
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "description": "The date range for which this agreement is in force. `end` is null for open-ended agreements."
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "Link.json"
      },
      "description": "Supplementary hyperlinks (e.g. to the full legal text)."
    }
  }
}
