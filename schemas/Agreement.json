{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/Agreement.json",
  "title": "Agreement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "specVersion",
    "title",
    "parties",
    "terms",
    "effective"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:srcos:agreement:",
      "description": "Stable URN identifying this agreement (urn:srcos:agreement:<id>)."
    },
    "type": {
      "const": "Agreement",
      "description": "Discriminator constant \u2014 always 'Agreement'."
    },
    "specVersion": {
      "type": "string",
      "description": "Semantic version of the SourceOS spec this record conforms to."
    },
    "title": {
      "type": "string",
      "description": "Short human-readable title of the agreement."
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "description": "Longer narrative description of the agreement's intent and scope."
    },
    "parties": {
      "type": "array",
      "items": {
        "$ref": "Party.json"
      },
      "minItems": 1,
      "description": "Ordered list of parties bound by this agreement."
    },
    "terms": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "license",
        "restrictions"
      ],
      "properties": {
        "license": {
          "type": "string"
        },
        "restrictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attributionRequired": {
          "type": "boolean",
          "default": false
        },
        "dataRetentionDays": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "jurisdiction": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "description": "License, restriction, attribution, retention, and jurisdiction terms."
    },
    "effective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start"
      ],
      "properties": {
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "description": "Validity window: start (required) and end (null = indefinite)."
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "Link.json"
      },
      "description": "Optional hypermedia links to related resources (e.g., full legal text)."
    }
  },
  "description": "A data usage agreement between two or more parties, specifying license terms, use restrictions, attribution requirements, data-retention period, and jurisdictional scope."
}