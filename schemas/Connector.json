{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/Connector.json",
  "title": "Connector",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "specVersion",
    "name",
    "kind",
    "config"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:srcos:connector:",
      "description": "Stable URN identifying this connector (urn:srcos:connector:<id>)."
    },
    "type": {
      "const": "Connector",
      "description": "Discriminator constant \u2014 always 'Connector'."
    },
    "specVersion": {
      "type": "string",
      "description": "Semantic version of the SourceOS spec this record conforms to."
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name for this connector."
    },
    "kind": {
      "enum": [
        "s3",
        "gcs",
        "azureBlob",
        "rdbms",
        "kafka",
        "filesystem",
        "httpApi",
        "lakehouse"
      ],
      "description": "Category of external system this connector targets."
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "description": "Connector-specific configuration (endpoint, auth strategy, etc.)."
    },
    "status": {
      "enum": [
        "active",
        "disabled",
        "deprecated"
      ],
      "default": "active",
      "description": "Operational status of this connector."
    }
  },
  "description": "A storage or compute connection descriptor defining the kind, endpoint configuration, and operational status of an external data source or sink."
}