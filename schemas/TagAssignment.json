{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/TagAssignment.json",
  "title": "TagAssignment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tag",
    "state",
    "confidence",
    "source"
  ],
  "properties": {
    "tag": {
      "type": "string"
    },
    "state": {
      "enum": [
        "inferred",
        "curated",
        "rejected"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source": {
      "enum": [
        "ml",
        "analyst",
        "rule",
        "import"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewedBy": {
          "type": [
            "string",
            "null"
          ]
        },
        "reviewedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "comment": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}