{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/TagAssignment.json",
  "title": "TagAssignment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tag",
    "state",
    "confidence",
    "source"
  ],
  "properties": {
    "tag": {
      "type": "string",
      "description": "The classification tag string (e.g., 'pii.email', 'financial.revenue')."
    },
    "state": {
      "enum": [
        "inferred",
        "curated",
        "rejected"
      ],
      "description": "Current curation state of this tag assignment."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score in the range [0, 1] from the detection source."
    },
    "source": {
      "enum": [
        "ml",
        "analyst",
        "rule",
        "import"
      ],
      "description": "How this tag was assigned."
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of evidence artifact names or descriptions supporting this tag."
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewedBy": {
          "type": [
            "string",
            "null"
          ]
        },
        "reviewedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "comment": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "description": "Human review details: reviewer URN, review timestamp, and a comment."
    }
  },
  "description": "A classification tag applied to a field, glossary term, or dataset column, recording the curation state, confidence score, detection source, supporting evidence, and human review details."
}