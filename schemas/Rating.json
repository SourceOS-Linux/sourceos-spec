{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/Rating.json",
  "title": "Rating",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "specVersion",
    "targetId",
    "rater",
    "createdAt",
    "value"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:srcos:rating:"
    },
    "type": {
      "const": "Rating"
    },
    "specVersion": {
      "type": "string"
    },
    "targetId": {
      "type": "string"
    },
    "rater": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "value": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    }
  }
}