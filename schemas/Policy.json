{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.srcos.ai/v2/Policy.json",
  "title": "Policy",
  "description": "An access-control policy. Combines a subject/object/purpose scope with permit/deny rules, pre/post obligations, and time-limited exceptions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "specVersion",
    "name",
    "scope",
    "rules",
    "obligations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^urn:srcos:policy:",
      "description": "Stable URN identifier. Pattern: urn:srcos:policy:<local-id>"
    },
    "type": {
      "const": "Policy",
      "description": "Discriminator constant \u2014 always \"Policy\"."
    },
    "specVersion": {
      "type": "string",
      "description": "Spec version of this document, e.g. \"2.0.0\"."
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the policy."
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subjects",
        "objects",
        "purposes"
      ],
      "properties": {
        "subjects": {
          "type": "array",
          "items": {
            "$ref": "SubjectSelector.json"
          }
        },
        "objects": {
          "type": "array",
          "items": {
            "$ref": "ObjectSelector.json"
          }
        },
        "purposes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Defines which subject kinds, object types, and purpose strings this policy applies to."
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "Rule.json"
      },
      "description": "The ordered list of permit/deny rules evaluated against the scope."
    },
    "obligations": {
      "type": "array",
      "items": {
        "$ref": "Obligation.json"
      },
      "description": "Actions that must be performed whenever this policy permits access."
    },
    "exceptions": {
      "type": "array",
      "items": {
        "$ref": "Exception.json"
      },
      "description": "Time-limited exemptions that override the normal rules."
    }
  }
}
